{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game-sprite-forge.local/schemas/gsfpack.schema.json",
  "title": "Game Sprite Forge Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "createdAt",
    "creator",
    "license",
    "source",
    "animations",
    "assets",
    "previews"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "creator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "import_video",
            "import_frames",
            "import_sprite_sheet",
            "import_gsfpack"
          ]
        },
        "name": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "animations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/animation"
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "qualityReport"],
      "properties": {
        "frames": {
          "type": "string",
          "minLength": 1
        },
        "spriteSheet": {
          "type": "string",
          "minLength": 1
        },
        "atlas": {
          "type": "string",
          "minLength": 1
        },
        "manifest": {
          "type": "string",
          "minLength": 1
        },
        "godotHelper": {
          "type": "string",
          "minLength": 1
        },
        "qualityReport": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "previews": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gif"],
      "properties": {
        "gif": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "animation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "frames"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "loop": {
          "type": "boolean"
        }
      }
    }
  }
}
