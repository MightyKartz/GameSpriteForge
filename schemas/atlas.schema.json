{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game-sprite-forge.local/schemas/atlas.schema.json",
  "title": "Game Sprite Forge Sprite Atlas",
  "type": "object",
  "additionalProperties": false,
  "required": ["image", "frameWidth", "frameHeight", "columns", "rows", "frames"],
  "properties": {
    "image": {
      "type": "string",
      "minLength": 1
    },
    "images": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "frameWidth": {
      "type": "integer",
      "minimum": 1
    },
    "frameHeight": {
      "type": "integer",
      "minimum": 1
    },
    "columns": {
      "type": "integer",
      "minimum": 1
    },
    "rows": {
      "type": "integer",
      "minimum": 1
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "name", "x", "y", "width", "height"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          },
          "page": {
            "type": "integer",
            "minimum": 0
          },
          "image": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
