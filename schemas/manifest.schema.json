{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game-sprite-forge.local/schemas/manifest.schema.json",
  "title": "Game Sprite Forge Engine Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "sheet", "animations", "anchor"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "frameWidth", "frameHeight", "columns", "rows"],
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1
        },
        "images": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "frameWidth": {
          "type": "integer",
          "minimum": 1
        },
        "frameHeight": {
          "type": "integer",
          "minimum": 1
        },
        "columns": {
          "type": "integer",
          "minimum": 1
        },
        "rows": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "animations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/animation"
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "x", "y"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["feet", "center", "custom"]
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    }
  },
  "$defs": {
    "animation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "frames"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "loop": {
          "type": "boolean"
        }
      }
    }
  }
}
